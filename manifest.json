{
  "manifest_version": 3,
  "name": "TheorieTestHelper",
  "version": "0.1.0",
  "description": "Translates German driving theory questions on theorie24.de to English",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.theorie24.de/*",
    "https://api.openai.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TheorieTestHelper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.theorie24.de/*", "http://localhost/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
